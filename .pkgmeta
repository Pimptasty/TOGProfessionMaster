package-as: TOGProfessionMaster

curseforge-project-id: 1513588

enable-toc-creation: no
enable-nolib-creation: yes

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

required-dependencies:
  - ace3
  - acecommqueue-1.0
  - versioncheck-1.0

optional-dependencies:
  - togbankclassic
  - greenwall

ignore:
  - .git/
  - .github/
  - .vscode/
  - docs/
  - "**/*.ps1"
  - "**/*.bat"
  - "*.code-workspace"
  - ".luarc.json"
  - "*.bat"
