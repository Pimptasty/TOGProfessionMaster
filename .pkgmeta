# .pkgmeta
package-as: TOGProfessionMaster

curseforge-project-id: 1513588

# Enable TOC file creation for multi-version support
enable-toc-creation: no
enable-nolib-creation: yes

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

# Keep noise out of the zip
ignore:
  - .git/
  - .github/
  - .vscode/
  - docs/
  - "**/*.ps1"
  - "**/*.bat"
  - "*.code-workspace"
  - ".luarc.json"
  - "*.bat"
